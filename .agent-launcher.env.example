# Launcher defaults for scripts/launch-agent.sh
# Copy to .agent-launcher.env and adjust as needed.

# Route options:
#   native     - use the CLI's normal provider/auth flow
#   proxy      - point Anthropic/OpenAI-compatible CLIs at your local proxy
#   openrouter - point compatible CLIs at OpenRouter
AGENT_ROUTE=proxy

# Mode options:
#   default    - normal interactive CLI
#   acp        - Agent Client Protocol server mode when the CLI supports it
AGENT_MODE=default

# Optional editor command for CLIs that honor EDITOR (for example opencode /editor)
# AGENT_EDITOR="code --wait"

# Local proxy defaults
AGENT_PROXY_URL=http://localhost:8082
AGENT_OPENAI_PROXY_URL=http://localhost:8082/v1
AGENT_PROXY_KEY=pass

# Claude proxy/OpenRouter defaults
CLAUDE_CODE_MAX_OUTPUT_TOKENS=128768

# OpenAI-compatible defaults for Codex/Qwen
# OPENAI_MODEL=gpt-5.2-codex

# OpenRouter API key for codex/qwen/claude/opencode when AGENT_ROUTE=openrouter
# OPENROUTER_API_KEY=sk-or-...

# Custom launcher example
# CUSTOM_AGENT_BIN=/home/cheta/bin/my-agent
# CUSTOM_AGENT_ARGS="--continue --verbose"
# CUSTOM_AGENT_ACP_ARGS="--acp"
