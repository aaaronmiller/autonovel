# API routing mode:
# - auto: prefer AUTONOVEL_* vars, then fall back to Claude Code env vars
# - autonovel: use AUTONOVEL_* vars first
# - claude_code: use Claude Code proxy/env vars first
AUTONOVEL_API_MODE=auto

# Project metadata used by exports, cover tooling, and starter assets.
AUTONOVEL_TITLE=Untitled Novel
AUTONOVEL_AUTHOR=Author Name
AUTONOVEL_SUBTITLE=A Novel
AUTONOVEL_TAGLINE=A fresh novel project generated with autonovel.
AUTONOVEL_DESCRIPTION=Use this landing page as a starter template for the current manuscript.
AUTONOVEL_WEBSITE=https://example.com

# Git behavior for the pipeline:
# 0 = never auto-commit or revert through git
# 1 = allow auto-commits from run_pipeline.py
AUTONOVEL_ENABLE_GIT=0

# Anthropic-compatible API credentials.
# Direct Anthropic usually uses ANTHROPIC_API_KEY.
# OpenRouter usually uses ANTHROPIC_AUTH_TOKEN and leaves ANTHROPIC_API_KEY empty.
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=

# Writer model (used for drafting and revision)
AUTONOVEL_WRITER_MODEL=claude-sonnet-4-6

# Judge model (used for evaluation — should differ from writer)
AUTONOVEL_JUDGE_MODEL=claude-sonnet-4-6

# Review model (Opus — deep prose-level analysis, used in Phase 3b)
AUTONOVEL_REVIEW_MODEL=claude-opus-4-6

# API base URL for repo-local routing
AUTONOVEL_API_BASE_URL=https://api.anthropic.com

# Optional repo-local auth overrides
# AUTONOVEL_API_KEY=
# AUTONOVEL_AUTH_TOKEN=

# Optional output cap applied to all Anthropic-compatible calls.
# If unset, the code honors CLAUDE_CODE_MAX_OUTPUT_TOKENS when present.
# AUTONOVEL_MAX_OUTPUT_TOKENS=128768

# Example: use the same local proxy setup as Claude Code
# AUTONOVEL_API_MODE=claude_code
# ANTHROPIC_BASE_URL=http://localhost:8082
# ANTHROPIC_API_KEY=pass
# CLAUDE_CODE_MAX_OUTPUT_TOKENS=128768

# Example: use OpenRouter's Anthropic-compatible endpoint directly
# AUTONOVEL_API_MODE=claude_code
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# ANTHROPIC_AUTH_TOKEN=sk-or-...
# ANTHROPIC_API_KEY=

# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
